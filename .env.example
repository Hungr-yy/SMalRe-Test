# Copy this file to .env and fill in your API keys.
# .env is in .gitignore and will NOT be committed.

# ---------------------------------------------------------------------------
# Teacher LLM API keys (all 3 required for the 3×3 experiment matrix)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Student SLM access (required for gated models like Llama 3.3)
# ---------------------------------------------------------------------------
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ---------------------------------------------------------------------------
# Google Cloud (required when using Vertex AI backend for student fine-tuning)
# ---------------------------------------------------------------------------
# Authentication – pick ONE option:
#   Option 1 (recommended): authenticate via gcloud CLI
#     gcloud auth application-default login
#
#   Option 2: set a service account key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Vertex AI project and staging bucket (required for all 3 student SLMs
# when student.backend = "vertex_ai" in model_config.yaml)
# These can also be set directly in configs/model_config.yaml under vertex_ai:
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_STAGING_BUCKET=
