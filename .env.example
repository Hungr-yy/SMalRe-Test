# Copy this file to .env and fill in your API keys.
# .env is in .gitignore and will NOT be committed.

# ---------------------------------------------------------------------------
# Teacher LLM API keys (all 3 required for the 3×3 experiment matrix)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Student SLM access
# ---------------------------------------------------------------------------
# Required for gated HuggingFace models (Llama 3.3 8B Instruct, Gemma 3 4B).
# Not needed for Qwen 2.5 7B Instruct (open access, Apache 2.0).
# You must also accept each model's license on its HuggingFace page.
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ---------------------------------------------------------------------------
# Google Cloud (required when using Vertex AI backend for student fine-tuning)
# ---------------------------------------------------------------------------
# Authentication – pick ONE option:
#   Option 1 (recommended): authenticate via gcloud CLI
#     gcloud auth application-default login
#
#   Option 2: set a service account key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Vertex AI project and staging bucket (required for all 3 student SLMs
# when student.backend = "vertex_ai" in model_config.yaml).
# These can also be set directly in configs/model_config.yaml under vertex_ai:
#
# Prerequisites:
#   - Billing must be enabled on the GCP project
#   - GPU quota for NVIDIA_L4 in your region (request at:
#     https://console.cloud.google.com/iam-admin/quotas)
#   - APIs enabled: aiplatform.googleapis.com, storage.googleapis.com
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=asia-southeast1
VERTEX_AI_STAGING_BUCKET=
